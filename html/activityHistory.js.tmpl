"use strict";

var ActivityHistory = {
    // Each cache entry: { dates: [], fetchedAt }
    cache: {},
    cacheTTL: 300000,
    maxCacheSize: 50,
    accessOrder: [], // LRU tracking: most recently used at end
    apiBaseUrl: 'https://__ROOT_PUB_DOMAIN_NAME__/api/aircraft/v2',

    hasActivity: function(icao) {
        var entry = this.cache[icao];
        return !!(entry && entry.dates && entry.dates.length > 0);
    },

    hasFetched: function(icao) {
        return !!this.cache[icao];
    },

    getCookie: function(name) {
        var value = '; ' + document.cookie;
        var parts = value.split('; ' + name + '=');
        if (parts.length === 2) return parts.pop().split(';').shift();
        return null;
    },

    toDateStr: function(date) {
        if (typeof date === 'string') return date;
        return date.getUTCFullYear() + '-' +
            String(date.getUTCMonth() + 1).padStart(2, '0') + '-' +
            String(date.getUTCDate()).padStart(2, '0');
    },

    _touch: function(icao) {
        var idx = this.accessOrder.indexOf(icao);
        if (idx !== -1) this.accessOrder.splice(idx, 1);
        this.accessOrder.push(icao);
    },

    _evictIfNeeded: function() {
        while (Object.keys(this.cache).length >= this.maxCacheSize && this.accessOrder.length > 0) {
            var oldest = this.accessOrder.shift();
            delete this.cache[oldest];
        }
    },

    _postActiveDates: function(icao) {
        var self = this;
        return new Promise(function(resolve) {
            grecaptcha.enterprise.ready(async function() {
                var token = await grecaptcha.enterprise.execute(
                    '6LfaIQ0oAAAAAC4GM95h8s4zirnKqJwX2y3L8Bor',
                    { action: 'ACTIVE_DATES' }
                );
                if (!token) { resolve([]); return; }
                try {
                    var response = await fetch(self.apiBaseUrl + '/operations/icao/active-dates', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({
                            user_token: token,
                            payload: { icao: icao }
                        })
                    });
                    if (!response.ok) { resolve([]); return; }
                    var data = await response.json();
                    resolve(data.active_dates || []);
                } catch(e) {
                    resolve([]);
                }
            });
        });
    },

    // Fetch all active dates for an ICAO (single request, ~1.3KB gzipped)
    fetchActiveDates: async function(icao) {
        var cached = this.cache[icao];
        if (cached && (Date.now() - cached.fetchedAt) < this.cacheTTL) {
            this._touch(icao);
            return cached.dates;
        }
        try {
            var dates = await this._postActiveDates(icao);
            this._evictIfNeeded();
            this.cache[icao] = {
                dates: dates,
                fetchedAt: Date.now()
            };
            this._touch(icao);
            return dates;
        } catch (e) {
            return [];
        }
    },

    getNextDate: function(icao, currentDate) {
        var cached = this.cache[icao];
        if (!cached || !cached.dates || !cached.dates.length) return null;
        var current = this.toDateStr(currentDate);
        var dates = cached.dates;
        for (var i = dates.length - 1; i >= 0; i--) {
            if (dates[i] > current) return dates[i];
        }
        return null;
    },

    getPrevDate: function(icao, currentDate) {
        var cached = this.cache[icao];
        if (!cached || !cached.dates || !cached.dates.length) return null;
        this._touch(icao);
        var current = this.toDateStr(currentDate);
        var dates = cached.dates;
        for (var i = 0; i < dates.length; i++) {
            if (dates[i] < current) return dates[i];
        }
        return null;
    },

    getActiveDatesSet: function(icao) {
        var entry = this.cache[icao];
        if (!entry || !entry.dates) return {};
        if (entry._activeSet) return entry._activeSet;
        var set = {};
        for (var i = 0; i < entry.dates.length; i++) {
            set[entry.dates[i]] = true;
        }
        entry._activeSet = set;
        return set;
    },

    clear: function(icao) {
        if (icao) {
            delete this.cache[icao];
            var idx = this.accessOrder.indexOf(icao);
            if (idx !== -1) this.accessOrder.splice(idx, 1);
        } else {
            this.cache = {};
            this.accessOrder = [];
        }
    }
};
